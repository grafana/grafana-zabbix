{
  "name": "grafana-zabbix",
  "version": "6.3.0",
  "description": "Zabbix plugin for Grafana",
  "homepage": "http://grafana-zabbix.org",
  "bugs": {
    "url": "https://github.com/grafana/grafana-zabbix/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grafana/grafana-zabbix.git"
  },
  "license": "Apache-2.0",
  "author": "Grafana Labs",
  "scripts": {
    "build": "webpack -c ./webpack.config.ts --env production",
    "dev": "webpack -w -c ./webpack.config.ts --env development",
    "e2e": "playwright test",
    "lint": "eslint --cache .",
    "lint:fix": "yarn run lint --fix && prettier --write --list-different .",
    "server": "docker compose up --build",
    "server:down": "docker compose --file ./devenv/default/docker-compose.yml down",
    "server:stop": "docker compose --file ./devenv/default/docker-compose.yml stop",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\"",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/data": "13.0.0",
    "@grafana/i18n": "13.0.0",
    "@grafana/plugin-ui": "0.13.1",
    "@grafana/runtime": "13.0.0",
    "@grafana/schema": "13.0.0",
    "@grafana/ui": "12.4.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-use": "17.6.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@babel/core": "7.29.0",
    "@changesets/cli": "2.30.0",
    "@grafana/e2e-selectors": "13.0.0",
    "@grafana/eslint-config": "9.0.0",
    "@grafana/plugin-e2e": "3.4.13",
    "@grafana/tsconfig": "2.0.1",
    "@openfeature/web-sdk": "1.7.3",
    "@playwright/test": "1.58.2",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@swc/core": "1.15.18",
    "@swc/helpers": "0.5.19",
    "@swc/jest": "0.2.39",
